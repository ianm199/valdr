{"id": "dieq-mismatch-still-there", "cmd": ["GET", "dieq:k2"]}
{"id": "dieq-setup-empty-value", "cmd": ["SET", "dieq:k3", ""]}
{"id": "dieq-match-empty-value", "cmd": ["DELIFEQ", "dieq:k3", ""]}
{"id": "dieq-empty-gone", "cmd": ["EXISTS", "dieq:k3"]}
{"id": "dieq-setup-multibyte", "cmd": ["SET", "dieq:k4", "alpha beta"]}
